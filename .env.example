# External API
NEXT_PUBLIC_API_BASE_URL=https://example-api.com
NEXT_PUBLIC_DAJI_ACCESS_KEY=your_public_access_key
NEXT_PUBLIC_DAJI_ACCESS_SECRET=your_public_or_test_secret_if_really_needed
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_YANDEX_PAY_ENV=sandbox
NEXT_PUBLIC_YANDEX_PAY_API_KEY=your_test_public_key
NEXT_PUBLIC_YANDEX_PAY_MERCHANT_ID=your_test_merchant_id
NEXT_PUBLIC_YANDEX_PAY_BASE_URL=https://pay.yandex.ru/api/merchant
NEXT_PUBLIC_YANDEX_PAY_REDIRECT_SUCCESS_URL=http://localhost:3000/cart/status/success
NEXT_PUBLIC_YANDEX_PAY_REDIRECT_ERROR_URL=http://localhost:3000/cart/status/error

# Cache settings
CACHE_MAX_SIZE=100
CACHE_TTL_MS=300000

# Authentication
JWT_SECRET=change_me
BCRYPT_SALT_ROUNDS=12

# CDN
CDN_URL=

# NextAuth
AUTH_SECRET=change_me
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me

# Email SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=example@example.com
SMTP_PASS=change_me
EMAIL_FROM=example@example.com
EMAIL_FROM_NAME=Arivoo

# Yandex Pay
YANDEX_PAY_ENV=sandbox
YANDEX_PAY_API_KEY=change_me
YANDEX_PAY_MERCHANT_ID=change_me
YANDEX_PAY_BASE_URL=https://pay.yandex.ru/api/merchant
YANDEX_PAY_REDIRECT_SUCCESS_URL=http://localhost:3000/cart/status/success
YANDEX_PAY_REDIRECT_ERROR_URL=http://localhost:3000/cart/status/error

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DATABASE_URL_UNPOOLED=postgresql://user:password@localhost:5432/dbname
PGHOST=localhost
PGHOST_UNPOOLED=localhost
PGUSER=user
PGDATABASE=dbname
PGPASSWORD=change_me

POSTGRES_URL=postgresql://user:password@localhost:5432/dbname
POSTGRES_URL_NON_POOLING=postgresql://user:password@localhost:5432/dbname
POSTGRES_USER=user
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=change_me
POSTGRES_DATABASE=dbname
POSTGRES_URL_NO_SSL=postgresql://user:password@localhost:5432/dbname
POSTGRES_PRISMA_URL=postgresql://user:password@localhost:5432/dbname